<!DOCTYPE html>
<html lang="en" class="phx-bg-white phx-antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <title>My Card Game</title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}>
    </script>
  </head>
  <body class="bg-white antialiased">
    <%!--
      Phoenix LiveView typically injects flash messages here.
      Example: <.flash_group flash={@flash} />
      This requires a CoreComponents.flash_group component.
    --%>
    <%= @inner_content %>
  </body>
</html>
